<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo Essen — Venta Directa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        /* ============================================================
           RESET & BASE
        ============================================================ */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --red:        #cc0e1a;
            --red-dark:   #9e0b14;
            --red-light:  #f9e5e7;
            --green:      #22c55e;
            --green-dark: #16a34a;
            --dark:       #111418;
            --mid:        #3a3f47;
            --muted:      #7a828f;
            --line:       #e8eaed;
            --bg:         #f5f4f0;
            --white:      #ffffff;
            --font-head:  'Playfair Display', Georgia, serif;
            --font-body:  'DM Sans', system-ui, sans-serif;
            --ease:       cubic-bezier(0.4, 0, 0.2, 1);
            --shadow-sm:  0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
            --shadow-md:  0 4px 16px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.05);
            --shadow-lg:  0 20px 40px rgba(0,0,0,.12);
            --r:          14px;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: var(--font-body);
            background: var(--bg);
            color: var(--dark);
            padding-top: 90px;
            -webkit-font-smoothing: antialiased;
        }

        img { display: block; max-width: 100%; }
        a { text-decoration: none; color: inherit; }

        /* ============================================================
           HEADER
        ============================================================ */
        header {
            position: fixed;
            inset: 0 0 auto 0;
            background: var(--white);
            border-bottom: 1px solid var(--line);
            z-index: 900;
            padding: 0 24px;
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 90px;
            gap: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-shrink: 0;
        }

        .brand-logo {
            width: 42px;
            height: 42px;
            background: var(--red);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .brand-logo svg { width: 26px; height: 26px; fill: white; }

        .brand-name {
            font-family: var(--font-head);
            font-size: 22px;
            font-weight: 900;
            color: var(--red);
            letter-spacing: -0.3px;
            line-height: 1;
        }

        .brand-sub {
            font-size: 11px;
            color: var(--muted);
            font-weight: 400;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-top: 3px;
        }

        .nav-group {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        /* ============================================================
           BOTONES
        ============================================================ */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 10px 20px;
            font-family: var(--font-body);
            font-size: 13.5px;
            font-weight: 600;
            border-radius: 40px;
            border: none;
            cursor: pointer;
            transition: transform .2s var(--ease), box-shadow .2s var(--ease), background .2s;
            white-space: nowrap;
            letter-spacing: .2px;
        }
        .btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
        .btn:active { transform: translateY(0); }

        .btn-ghost {
            background: transparent;
            border: 1.5px solid var(--line);
            color: var(--mid);
        }
        .btn-ghost:hover { border-color: var(--red); color: var(--red); background: var(--red-light); }

        .btn-dark {
            background: var(--dark);
            color: var(--white);
        }
        .btn-dark:hover { background: var(--mid); }

        .btn-wa {
            background: var(--green);
            color: var(--white);
        }
        .btn-wa:hover { background: var(--green-dark); }

        .btn-wa-full {
            background: var(--green);
            color: var(--white);
            width: 100%;
            justify-content: center;
            padding: 14px;
            border-radius: 10px;
            font-size: 14.5px;
            margin-top: auto;
            box-shadow: 0 4px 12px rgba(34,197,94,.25);
        }
        .btn-wa-full:hover { background: var(--green-dark); box-shadow: 0 6px 20px rgba(34,197,94,.35); }

        /* ============================================================
           HERO BANNER
        ============================================================ */
        .hero {
            background: var(--dark);
            color: var(--white);
            padding: 80px 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 60% 80% at 15% 50%, rgba(204,14,26,.18) 0%, transparent 70%),
                radial-gradient(ellipse 50% 60% at 85% 30%, rgba(204,14,26,.12) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-inner {
            max-width: 700px;
            margin: 0 auto;
            position: relative;
        }

        .hero-badge {
            display: inline-block;
            background: rgba(204,14,26,.2);
            border: 1px solid rgba(204,14,26,.4);
            color: #ff8a8a;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 6px 16px;
            border-radius: 40px;
            margin-bottom: 24px;
        }

        .hero h1 {
            font-family: var(--font-head);
            font-size: clamp(36px, 6vw, 60px);
            font-weight: 900;
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 20px;
        }

        .hero h1 span { color: var(--red); }

        .hero p {
            font-size: 17px;
            color: rgba(255,255,255,.65);
            max-width: 480px;
            margin: 0 auto 36px;
            line-height: 1.6;
            font-weight: 300;
        }

        .hero-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .hero-actions .btn {
            padding: 14px 28px;
            font-size: 15px;
        }

        /* ============================================================
           CONTAINER & LAYOUT
        ============================================================ */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* ============================================================
           SECTION HEADERS
        ============================================================ */
        .section-wrap {
            padding: 70px 0 20px;
        }

        .section-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 36px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--line);
            gap: 16px;
        }

        .section-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--red);
            margin-bottom: 8px;
        }

        .section-title {
            font-family: var(--font-head);
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 900;
            color: var(--dark);
            line-height: 1.15;
            letter-spacing: -0.5px;
        }

        .section-count {
            font-size: 13px;
            color: var(--muted);
            font-weight: 400;
            flex-shrink: 0;
        }

        /* ============================================================
           PRODUCT GRID
        ============================================================ */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
            gap: 24px;
        }

        /* ============================================================
           PRODUCT CARD
        ============================================================ */
        .card {
            background: var(--white);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--line);
            display: flex;
            flex-direction: column;
            transition: transform .3s var(--ease), box-shadow .3s var(--ease);
            opacity: 0;
            transform: translateY(20px);
            animation: fadeUp .5s var(--ease) forwards;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
        }

        @keyframes fadeUp {
            to { opacity: 1; transform: translateY(0); }
        }

        /* Stagger delay for cards */
        .card:nth-child(1)  { animation-delay: .05s; }
        .card:nth-child(2)  { animation-delay: .10s; }
        .card:nth-child(3)  { animation-delay: .15s; }
        .card:nth-child(4)  { animation-delay: .20s; }
        .card:nth-child(5)  { animation-delay: .25s; }
        .card:nth-child(6)  { animation-delay: .30s; }
        .card:nth-child(7)  { animation-delay: .35s; }
        .card:nth-child(8)  { animation-delay: .40s; }
        .card:nth-child(9)  { animation-delay: .45s; }
        .card:nth-child(10) { animation-delay: .50s; }

        .card-visual {
            height: 210px;
            background: linear-gradient(135deg, #f0eeea 0%, #e8e5df 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .card-visual::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--red), transparent);
            opacity: 0;
            transition: opacity .3s;
        }

        .card:hover .card-visual::after { opacity: 1; }

        /* SVG product icons */
        .product-icon {
            width: 90px;
            height: 90px;
            opacity: .85;
            transition: transform .3s var(--ease);
            filter: drop-shadow(0 8px 16px rgba(0,0,0,.15));
        }
        .card:hover .product-icon { transform: scale(1.08) translateY(-4px); }

        .card-body {
            padding: 24px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .card-cat {
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            color: var(--red);
        }

        .card-title {
            font-family: var(--font-head);
            font-size: 19px;
            font-weight: 700;
            color: var(--dark);
            line-height: 1.25;
        }

        .card-desc {
            font-size: 13.5px;
            color: var(--muted);
            line-height: 1.65;
            font-weight: 400;
            flex-grow: 1;
        }

        /* ============================================================
           DIVIDER
        ============================================================ */
        .section-divider {
            height: 1px;
            background: var(--line);
            margin: 10px 0 0;
        }

        /* ============================================================
           FOOTER
        ============================================================ */
        footer {
            background: var(--dark);
            color: var(--white);
            margin-top: 100px;
        }

        .footer-top {
            padding: 70px 24px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

        .footer-top-inner {
            max-width: 560px;
            margin: 0 auto;
        }

        .footer-eyebrow {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--red);
            margin-bottom: 16px;
        }

        .footer-heading {
            font-family: var(--font-head);
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 900;
            line-height: 1.15;
            margin-bottom: 16px;
        }

        .footer-sub {
            font-size: 15px;
            color: rgba(255,255,255,.55);
            margin-bottom: 36px;
            font-weight: 300;
        }

        .footer-phone {
            font-family: var(--font-head);
            font-size: 36px;
            font-weight: 900;
            color: var(--green);
            margin-bottom: 28px;
            letter-spacing: -1px;
        }

        .footer-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .footer-actions .btn {
            padding: 15px 32px;
            font-size: 15px;
        }

        .footer-bottom {
            padding: 20px 24px;
            text-align: center;
            font-size: 12px;
            color: rgba(255,255,255,.3);
        }

        /* ============================================================
           RESPONSIVE
        ============================================================ */
        @media (max-width: 768px) {
            body { padding-top: 70px; }

            .header-inner {
                height: 70px;
                flex-wrap: wrap;
                justify-content: space-between;
            }

            .nav-group {
                display: none; /* hamburger would go here; kept simple */
            }

            .mobile-wa {
                display: inline-flex !important;
            }

            .hero { padding: 60px 20px; }

            .section-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @media (max-width: 480px) {
            .grid { grid-template-columns: 1fr; }
        }

        /* mobile WA shortcut in header */
        .mobile-wa {
            display: none;
        }

        /* ============================================================
           SCROLL REVEAL (JS-assisted)
        ============================================================ */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity .6s var(--ease), transform .6s var(--ease);
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ============================================================
           STICKY SECTION ANCHORS (offset for fixed header)
        ============================================================ */
        .anchor-offset {
            display: block;
            height: 110px;
            margin-top: -110px;
            visibility: hidden;
            pointer-events: none;
        }

    </style>
</head>
